{
  "name": "zudo-pd-doc",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:network": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro sync && pnpm run format:mdx && tsc --noEmit",
    "b4push": "./scripts/run-b4push.sh",
    "prepare": "lefthook install --reset-hooks-path",
    "format:mdx": "pnpm dlx @takazudo/mdx-formatter --write \"src/content/**/*.{md,mdx}\"",
    "format:astro": "prettier --write \"src/**/*.astro\"",
    "format": "pnpm run format:mdx && pnpm run format:astro",
    "format:check:mdx": "pnpm dlx @takazudo/mdx-formatter --check \"src/content/**/*.{md,mdx}\"",
    "format:check:astro": "prettier --check \"src/**/*.astro\"",
    "format:check": "pnpm run format:check:mdx && pnpm run format:check:astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/preact": "^5.0.0",
    "@shikijs/transformers": "^4.0.1",
    "@types/hast": "^3.0.4",
    "astro": "^6.0.4",
    "clsx": "^2.1.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "mermaid": "^11.12.3",
    "minisearch": "^7.2.0",
    "preact": "^10.26.9",
    "remark-directive": "^4.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@tailwindcss/vite": "^4.2.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
