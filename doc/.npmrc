auto-install-peers=true

# zfb-adapter-cloudflare's emitted bundle resolves miniflare via filesystem
# traversal from the bundle/workspace root, not via Node require resolution.
# Under pnpm's strict isolation, miniflare lives only under node_modules/.pnpm/,
# so the bundle cannot find it during `zfb build`'s paths() step. Hoist it to
# the top-level node_modules so the CF adapter build resolves it (matches the
# zudo-doc framework's own .npmrc).
public-hoist-pattern[]=miniflare
