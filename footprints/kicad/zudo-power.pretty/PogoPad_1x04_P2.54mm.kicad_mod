(module PogoPad_1x04_P2.54mm (layer F.Cu) (tedit 65F0A000)
	(descr "4-pin pogo pad array for edge-clamp programming clip (2.54mm pitch). Bare copper exposed (F.Mask opened), no solder paste. Must be placed at PCB edge on the side where the silkscreen line sits.")
	(tags "pogo test programming i2c stusb4500")
	(attr smd)
	(fp_text reference REF** (at 0 -3.8) (layer F.SilkS)
		(effects (font (size 1 1) (thickness 0.15)))
	)
	(fp_text value PogoPad_1x04 (at 0 3.8) (layer F.Fab)
		(effects (font (size 0.8 0.8) (thickness 0.12)))
	)
	(fp_text user %R (at 0 0) (layer F.Fab)
		(effects (font (size 0.8 0.8) (thickness 0.12)))
	)
	(fp_text user "SCL" (at -3.81 2.2) (layer F.SilkS)
		(effects (font (size 0.7 0.7) (thickness 0.12)))
	)
	(fp_text user "SDA" (at -1.27 2.2) (layer F.SilkS)
		(effects (font (size 0.7 0.7) (thickness 0.12)))
	)
	(fp_text user "GND" (at 1.27 2.2) (layer F.SilkS)
		(effects (font (size 0.7 0.7) (thickness 0.12)))
	)
	(fp_text user "NC" (at 3.81 2.2) (layer F.SilkS)
		(effects (font (size 0.7 0.7) (thickness 0.12)))
	)
	(fp_line (start -5.5 -1.8) (end 5.5 -1.8) (layer F.SilkS) (width 0.15))
	(fp_text user "<-- EDGE" (at 0 -2.4) (layer F.SilkS)
		(effects (font (size 0.6 0.6) (thickness 0.1)))
	)
	(pad 1 smd rect (at -3.81 0 0) (size 1.5 2.5) (layers F.Cu F.Mask))
	(pad 2 smd rect (at -1.27 0 0) (size 1.5 2.5) (layers F.Cu F.Mask))
	(pad 3 smd rect (at 1.27 0 0) (size 1.5 2.5) (layers F.Cu F.Mask))
	(pad 4 smd rect (at 3.81 0 0) (size 1.5 2.5) (layers F.Cu F.Mask))
)
